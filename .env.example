# Databricks configuration
# Copy this file to .env and fill in your values

# Databricks workspace URL (e.g., https://adb-1234567890.12.azuredatabricks.net)
DATABRICKS_HOST=

# Databricks personal access token
DATABRICKS_TOKEN=

# Optional: MLflow tracking URI (defaults to Databricks MLflow)
# MLFLOW_TRACKING_URI=databricks
